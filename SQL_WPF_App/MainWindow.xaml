<Window x:Class="SQL_WPF_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Интерпретатор SQL" Height="70" Width="650"
        WindowStartupLocation="CenterScreen" Icon="MainIcon.ico">

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#D7E4F2" Height="30" Padding="5">
            <MenuItem Header="Команды">
                <MenuItem Header="Создать" Click="CreateItem_Click"/>
                <MenuItem Header="Открыть" Click="OpenItem_Click"/>
                <MenuItem Header="Структура" Click="StructureItem_Click"/>
                <MenuItem Header="Сжать" Click="ShrinkItem_Click"/>
                <MenuItem Header="Закрыть" Click="CloseItem_Click"/>
                <MenuItem Header="Удалить" Click="DropItem_Click"/>
                <MenuItem Header="Данные" Click="DataItem_Click"/>
                <MenuItem Header="Запрос" Click="QueryItem_Click"/>
                <Separator/>
                <MenuItem Header="Выход" Click="ExitItem_Click"/>
            </MenuItem>
            <MenuItem Header="Создать" Click="CreateItem_Click"/>
            <MenuItem Header="Открыть" Click="OpenItem_Click"/>
            <MenuItem Header="Структура" Click="StructureItem_Click"/>
            <MenuItem Header="Сжать" Click="ShrinkItem_Click"/>
            <MenuItem Header="Закрыть" Click="CloseItem_Click"/>
            <MenuItem Header="Удалить" Click="DropItem_Click"/>
            <MenuItem Header="Данные" Click="DataItem_Click"/>
            <MenuItem Header="Запрос" Click="QueryItem_Click"/>
            <MenuItem Header="Выход" Click="ExitItem_Click"/>
            <MenuItem Header="?" Click="HelpItem_Click"/>
        </Menu>

        <!-- DataGridView для результатов -->
        <DataGrid x:Name="dgvResult" 
                  AutoGenerateColumns="True" 
                  IsReadOnly="True" 
                  RowHeaderWidth="0"
                  Background="White"/>
    </DockPanel>
</Window>