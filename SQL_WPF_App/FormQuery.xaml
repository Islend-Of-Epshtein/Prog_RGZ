<Window x:Class="SQL_WPF_App.FormQuery"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Интерпретатор SQL - выполнение SQL-запроса" Height="370" Width="515"
        WindowStartupLocation="CenterScreen" Icon="Icons/FormsIcon.ico">
    <DockPanel Background="#DEDEDE">
        <Menu DockPanel.Dock="Top" Background="#E1E1E1" Height="25">
            <MenuItem Header="Выполнить" Padding="15,2,10,0" Click="BtnExecute_Click"/>
            <MenuItem Header="Очистить" Padding="5,2,10,0" Click="BtnClear_Click"/>
            <MenuItem Header="Закрыть" Padding="5,2,10,0" Click="BtnClose_Click"/>
        </Menu>
        <Grid DockPanel.Dock="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0">
                <TextBox  x:Name="txtInput" VerticalScrollBarVisibility="Auto" 
                        FontFamily="Consolas" FontSize="12" Margin="1,0,1,0" AcceptsReturn="True"/>
            </ScrollViewer>
            <Border Grid.Row="1" BorderBrush="#8F8F8F" BorderThickness="1"
                         Background="#E3E3E3"/>
            <DataGrid Grid.Row="2" x:Name="dgvOutput" AutoGenerateColumns="True" 
                        IsReadOnly="True" RowHeaderWidth="0" Margin="1,0,1,0" Background="#FFA0A0A0" HeadersVisibility="None"/>
        </Grid>
    </DockPanel>
</Window>