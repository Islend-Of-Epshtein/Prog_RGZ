<Window x:Class="SQL_WPF_App.FormDataView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Интерпретатор SQL - Данные таблицы" Height="370" Width="550"
        WindowStartupLocation="CenterScreen" Icon="Icons/FormsIcon.ico">

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#E1E1E1" Height="25">
            <MenuItem Header="Добавить" Padding="15,2,10,0" Click="BtnAdd_Click"/>
            <MenuItem Header="Изменить" Padding="5,2,10,0" Click="BtnEdit_Click"/>
            <MenuItem Header="Удалить" Padding="5,2,10,0" Click="BtnDelete_Click"/>
            <MenuItem Header="Обновить" Padding="5,2,10,0" Click="BtnRefresh_Click"/>
            <MenuItem Header="Закрыть" Padding="5,2,10,0" Click="BtnClose_Click"/>
        </Menu> 
        <DataGrid DockPanel.Dock="Bottom" x:Name="dgvData" AutoGenerateColumns="True" IsReadOnly="True" 
                  RowHeaderWidth="0" SelectionMode="Single" Background="White"/>
    </DockPanel>
</Window>