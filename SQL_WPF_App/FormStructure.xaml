<Window x:Class="SQL_WPF_App.FormStructure"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Структура таблицы" Height="400" Width="600"
        WindowStartupLocation="CenterScreen" Icon="/FormsIcon.ico">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" Click="AddButton_Click" Width="100" Margin="0,0,10,0"/>
            <Button Content="Удалить" Click="DeleteButton_Click" Width="100" Margin="0,0,10,0"/>
            <Button Content="Закрыть" Click="CloseButton_Click" Width="100"/>
        </StackPanel>

        <DataGrid x:Name="dgvStructure" AutoGenerateColumns="False" IsReadOnly="True" RowHeaderWidth="0" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя поля" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                <DataGridTextColumn Header="Длина" Binding="{Binding Width}" Width="80"/>
                <DataGridTextColumn Header="Точность" Binding="{Binding Precision}" Width="80"/>
                <DataGridCheckBoxColumn Header="NOT NULL" Binding="{Binding IsNotNull}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>